# Telegram Bot (used as file storage)
TELEGRAM_BOT_TOKEN=123456789:your-bot-token-here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Server
PORT=3000

# Comma-separated list of allowed origins for CORS (your website domain)
ALLOWED_ORIGINS=https://yourusername.github.io,http://localhost:5500
